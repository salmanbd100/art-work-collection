{
  "name": "art-work-collection",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:coverage": "ng test --coverage",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "prepare": "husky",
    "dev:ssr": "ng run art-work-collection:serve-ssr",
    "serve:ssr": "node dist/art-work-collection/server/main.js",
    "build:ssr": "ng build && ng run art-work-collection:server",
    "prerender": "ng run art-work-collection:prerender"
  },
  "private": true,
  "engines": {
    "node": ">=20.19"
  },
  "packageManager": "pnpm@9.15.0",
  "dependencies": {
    "@angular/animations": "^21.2.13",
    "@angular/cdk": "21.2.10",
    "@angular/common": "^21.2.13",
    "@angular/compiler": "^21.2.13",
    "@angular/core": "^21.2.13",
    "@angular/forms": "^21.2.13",
    "@angular/material": "21.2.10",
    "@angular/platform-browser": "^21.2.13",
    "@angular/platform-browser-dynamic": "^21.2.13",
    "@angular/platform-server": "^21.2.13",
    "@angular/router": "^21.2.13",
    "@angular/ssr": "^21.2.11",
    "express": "^5.1.0",
    "rxjs": "~7.5.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.5.1",
    "@analogjs/vitest-angular": "^2.5.1",
    "@angular-devkit/build-angular": "^21.2.11",
    "@angular-eslint/builder": "21.4.0",
    "@angular/cli": "^21.2.11",
    "@angular/compiler-cli": "^21.2.13",
    "@eslint/js": "^10.0.1",
    "@testing-library/angular": "^19.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^5.0.1",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^22.19.19",
    "@vitest/coverage-v8": "^4.1.6",
    "angular-eslint": "21.4.0",
    "browser-sync": "^3.0.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "9.0.11",
    "jsdom": "^29.1.1",
    "lint-staged": "15.2.10",
    "prettier": "^3.8.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "8.59.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.6"
  }
}
